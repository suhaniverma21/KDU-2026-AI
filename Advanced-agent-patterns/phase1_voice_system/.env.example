# Example environment variables for the Phase 1 voice system.
OPENAI_API_KEY=
DEFAULT_LLM_MODEL=gpt-4o-mini
DEFAULT_STT_MODEL=whisper-1
DEFAULT_TTS_MODEL=tts-1
DEFAULT_TTS_VOICE=alloy
VOICE_SAMPLE_RATE=16000
VOICE_CHUNK_SIZE=1024
VOICE_SILENCE_THRESHOLD=250
VOICE_SILENCE_DURATION_SECONDS=1.2
VOICE_MAX_RECORD_SECONDS=20.0
VOICE_INTERRUPT_ENABLED=false
VOICE_INTERRUPT_ACTIVATION_CHUNKS=3
VOICE_INTERRUPT_MIN_CHARS=12
VOICE_INTERRUPT_MAX_RESTARTS=2
PLAYBACK_WAIT_TIMEOUT_SECONDS=20.0
PREFERRED_INPUT_DEVICE_NAME=Logi USB Headset
PREFERRED_OUTPUT_DEVICE_NAME=Logi USB Headset
VOICE_INPUT_DEVICE_INDEX=
TTS_OUTPUT_DEVICE_INDEX=
VOICE_CHANNELS=1
VOICE_DTYPE=int16
TTS_SAMPLE_RATE=24000
TTS_CHANNELS=1
TTS_SAMPLE_WIDTH_BYTES=2
TTS_STREAM_CHUNK_SIZE=4096
