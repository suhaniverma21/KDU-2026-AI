# Example environment variables for the standalone Phase 3 scaling and monitoring project.
OPENAI_API_KEY=sk-your-openai-api-key
MAX_CONCURRENT_USERS=100
MAX_CONCURRENT_DB_REQUESTS=10
MAX_QUEUE_WAIT_SECONDS=5
MAX_TOKENS_PER_HANDOFF=2000
SUMMARY_KEEP_LAST_N_EXCHANGES=5
LOG_FILE_PATH=logs/phase3_events.jsonl
MAX_LOG_FILE_SIZE_MB=10
COST_PER_INPUT_TOKEN=0.00000015
COST_PER_OUTPUT_TOKEN=0.0000006
FALLBACK_RESPONSE=System is busy, please try again.
