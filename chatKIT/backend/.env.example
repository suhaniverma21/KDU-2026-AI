FRONTEND_ORIGIN=http://localhost:3000
OPENAI_API_KEY=your-openai-api-key
# Optional if you store PEM files as backend/jwt-private.pem and backend/jwt-public.pem
# JWT_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nreplace-me\n-----END PRIVATE KEY-----
# JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nreplace-me\n-----END PUBLIC KEY-----
JWT_ALGORITHM=RS256
JWT_COOKIE_NAME=travel_app_session
JWT_TTL_SECONDS=86400
REFRESH_WINDOW_SECONDS=300
CLIENT_SECRET_TTL_SECONDS=900
SESSION_RATE_LIMIT_PER_MINUTE=10
CHAT_RATE_LIMIT_PER_MINUTE=60
ALLOW_INSECURE_COOKIES=true
AGENT_DEMO_KEY=demo-agent-key
AGENT_DISCONNECT_GRACE_SECONDS=30
